# Copy to `.env` for local dev. `.env` is gitignored — never commit it.

# =============================================================================
# Report API — https://pu.playtonight.fun/api/payment/report/bucket-wise?date=YYYY-MM-DD
# =============================================================================

# Option A — Call PlayTonight directly (requires CORS for your dashboard origin):
# VITE_API_BASE_URL=https://pu.playtonight.fun

# Option B — Same-origin proxy (Netlify `netlify.toml` + Vite dev server). Omit VITE_API_BASE_URL.
VITE_API_REPORT_ENDPOINT=/api/payment/report/bucket-wise

# =============================================================================
# Login — use ONE of the following
# =============================================================================

# Production / staging: POST JSON { "email", "password" }; optional { "token" } for report Bearer auth
# VITE_AUTH_LOGIN_URL=https://your-api.example.com/api/auth/login

# Local demo (leave VITE_AUTH_LOGIN_URL unset). Change or remove before production deploy.
VITE_FALLBACK_LOGIN_EMAIL=admin@gmail.com
VITE_FALLBACK_LOGIN_PASSWORD=Admin@123

# =============================================================================
# Optional
# =============================================================================

VITE_APP_TITLE=Nutra Dashboard
# VITE_DATE_RANGE_MAX_DAYS=31
# VITE_CONTACT_DETAILS_URL=
