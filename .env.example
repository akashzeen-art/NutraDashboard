# Copy to `.env` and adjust. Never commit real `.env`.

# Report API (required): origin + path to bucket-wise endpoint
VITE_API_BASE_URL=https://your-api.example.com
VITE_API_REPORT_ENDPOINT=/api/payment/report/bucket-wise
# Example: VITE_API_BASE_URL=https://pu.playtonight.fun
#           VITE_API_REPORT_ENDPOINT=/api/payment/report/bucket-wise

# Login: prefer API — POST JSON { "email", "password" }; optional response { "token" } for Bearer report calls
VITE_AUTH_LOGIN_URL=https://your-api.example.com/api/auth/login

# Local demo only (leave VITE_AUTH_LOGIN_URL empty): match email/password from env — do not use in production
# VITE_FALLBACK_LOGIN_EMAIL=
# VITE_FALLBACK_LOGIN_PASSWORD=

# Optional: UI title on login + dashboard header
VITE_APP_TITLE=Nutra Dashboard

# Optional: max days per date range (default 31 if unset)
VITE_DATE_RANGE_MAX_DAYS=31

# Optional: GET contact details URL template — {mobile} {date} {productId}
# VITE_CONTACT_DETAILS_URL=
